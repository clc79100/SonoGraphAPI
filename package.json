{
  "name": "sonograph-api",
  "version": "0.1.0",
  "description": "Sonograph backend — NestJS API",
  "private": true,
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "typeorm": "npm run build && npx typeorm -d dist/core/db/data-source.js",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "seed": "npm run build && node dist/core/db/seed.js",
    "perf:load": "k6 run perf/load.ts",
    "perf:stress": "k6 run perf/stress.ts",
    "perf:spike": "k6 run perf/spike.ts",
    "perf:soak": "k6 run perf/soak.ts",
    "perf:all": "k6 run perf/load.ts && k6 run perf/stress.ts && k6 run perf/spike.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/testing": "^10.4.22",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "applicationinsights": "^3.15.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "winston-azure-application-insights": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@testcontainers/postgresql": "^12.0.3",
    "@testcontainers/redis": "^12.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
